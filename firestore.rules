rules_version = '2';
// DevSocio Firestore security rules (PRD §7.2).
// Signed-in users can read the public app; writes are scoped to the owner.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return signedIn() && request.auth.token.email == 'sampathlox@gmail.com';
    }
    // A user the admin has banned cannot create new content (one read per write).
    function isBanned() {
      return signedIn()
        && !isAdmin()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.banned == true;
    }
    // The owner account (by email on the doc) can never be banned or stripped
    // of verified/moderator — even by an admin write. Applies to user updates.
    function protectsOwner() {
      return !(resource.data.email == 'sampathlox@gmail.com'
        && (request.resource.data.banned == true
            || request.resource.data.verified == false
            || request.resource.data.moderator == false));
    }

    // ---- Users & their private subcollections ----
    match /users/{uid} {
      allow read: if signedIn();
      // Static hosting (no server): credit earning runs client-side, so owners
      // may update their own profile incl. credits. Admin may update anyone.
      allow create: if isUser(uid);
      allow update: if (isAdmin() || (
        isUser(uid) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['moderator'])
      ) || (
        signedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount'])
      )) && protectsOwner();
      allow delete: if false;

      // Bookmarks and follow edges belong to the user. Follower/following
      // counters on *other* users' docs are bumped with increment() and are
      // permitted by the broad user update rule above.
      match /saves/{postId} {
        allow read, write: if isUser(uid);
      }
      match /following/{targetUid} {
        allow read: if signedIn();
        allow write: if isUser(uid);
      }
      // Notifications: the owner reads/updates; anyone signed-in may create one
      // (e.g. someone liking your post writes to your notifications feed).
      match /notifications/{notifId} {
        allow read, update, delete: if isUser(uid);
        allow create: if signedIn();
      }
      // Credit transaction log — owner can read; created by owner (client) or
      // Admin SDK (server). Immutable: no updates or deletes permitted.
      match /credits_log/{logId} {
        allow read: if isUser(uid);
        allow create: if isUser(uid) || isAdmin();
        allow update, delete: if false;
      }
    }

    // ---- Posts, their likes and comments ----
    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid && !isBanned();
      // Author can edit/delete; any signed-in user may bump counters
      // (likes / commentsCount) when interacting with the post. Admin may
      // delete any post for moderation.
      allow update: if signedIn() && (
        resource.data.authorUid == request.auth.uid ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentsCount'])
      );
      allow delete: if isAdmin() || (signedIn() && resource.data.authorUid == request.auth.uid);

      match /likes/{uid} {
        allow read: if signedIn();
        allow create, delete: if isUser(uid);
      }
      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid && !isBanned();
        // Any signed-in user may bump likesCount; author/admin can delete.
        allow update: if signedIn() && (
          resource.data.authorUid == request.auth.uid ||
          isAdmin() ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount'])
        );
        allow delete: if isAdmin() || (signedIn() && resource.data.authorUid == request.auth.uid);

        match /likes/{uid} {
          allow read: if signedIn();
          allow create, delete: if isUser(uid);
        }
      }
    }

    // collectionGroup query over all "likes" (which posts a user liked).
    match /{path=**}/likes/{uid} {
      allow read: if signedIn();
    }

    // collectionGroup query over all "following" (to find followers of a user).
    match /{path=**}/following/{targetUid} {
      allow read: if signedIn();
    }

    // ---- Ideas board ----
    match /ideas/{ideaId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid && !isBanned();
      // Author edits; any signed-in user may invest (increment) into an idea.
      allow update: if signedIn() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['invested'])
      );
      allow delete: if signedIn() && resource.data.authorUid == request.auth.uid;
    }

    // ---- Stories (24h) ----
    match /stories/{storyId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid && !isBanned();
      // Any signed-in user may react (update reactions map); author/admin delete.
      allow update: if signedIn() && (
        resource.data.authorUid == request.auth.uid ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'viewers'])
      );
      allow delete: if isAdmin() || (signedIn() && resource.data.authorUid == request.auth.uid);
    }

    // ---- Reports & moderation ----
    match /reports/{reportId} {
      allow create: if signedIn() && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // ---- Error capture (Admin Copilot) ----
    // Any signed-in client may log a crash; only the admin can read/resolve.
    match /errors/{errorId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    // ---- Monitoring digest (written by the cron via Admin SDK) ----
    // Admin reads it in the panel; client writes are denied (server bypasses).
    match /admin_digests/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /conversations/{cid} {
      // Reading a not-yet-created conversation is harmless (returns nothing);
      // tolerate a null resource so opening a fresh chat never errors.
      allow read: if signedIn() && (resource == null || request.auth.uid in resource.data.members);
      // A write must also name the caller as a member of the new/updated doc.
      allow create: if signedIn() && request.auth.uid in request.resource.data.members;
      allow update: if signedIn() && (
        request.auth.uid in resource.data.members ||
        request.auth.uid in request.resource.data.members
      );

      match /messages/{messageId} {
        allow read: if signedIn() && (
          !exists(/databases/$(database)/documents/conversations/$(cid)) ||
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.members
        );
        allow create: if signedIn() && request.resource.data.from == request.auth.uid && (
          !exists(/databases/$(database)/documents/conversations/$(cid)) ||
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.members
        );
      }
    }
  }
}
