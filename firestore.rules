rules_version = '2';
// DevSocio Firestore security rules (PRD §7.2).
// - Users can only write their own profile doc.
// - Signed-in users can read profiles and the public feed.
// - Posts can be created by their author and edited/deleted only by them.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.authorUid == request.auth.uid;
    }

    match /{path=**}/comments/{commentId} {
      allow read: if signedIn();
      allow create: if signedIn();
    }
  }
}
