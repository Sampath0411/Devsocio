rules_version = '2';
// DevSocio Cloud Storage rules — avatars and post/idea images.
// Images are public-read (they're shown in feeds/profiles); a signed-in user
// may only write into their own folder, images only, max 8 MB.
service firebase.storage {
  match /b/{bucket}/o {
    match /uploads/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
