# ----- Local development only (vite dev) -----
# Used directly by the browser during `npm run dev`. These VITE_ vars are
# dead-code-eliminated from production builds (prod calls /api/ai instead),
# so they never ship to users. Get a key at https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_OPENROUTER_MODEL=openai/gpt-oss-120b:free

# ----- Image uploads (optional — Cloudinary unsigned upload, free) -----
# Without these, the UI falls back to pasting an image URL.
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_PRESET=your-unsigned-preset

# ----- Production (set these in Vercel → Settings → Environment Variables) -----
# Server-only — NOT prefixed with VITE_, so they stay on the server.
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# FIREBASE_SERVICE_ACCOUNT={...service account json...}   # for credits/referrals + admin agent

# ----- Admin Copilot (the in-admin AI agent — api/agent.js) -----
# Uses OpenRouter — reuses the SAME OPENROUTER_API_KEY above. The agent needs a
# model that supports tool/function calling (most free models do NOT), so set
# AGENT_MODEL to a tool-capable model. Defaults to openai/gpt-4o-mini.
# AGENT_MODEL=openai/gpt-4o-mini                       # e.g. openai/gpt-4o-mini, anthropic/claude-3.5-haiku
# ADMIN_EMAIL=sampathlox@gmail.com                     # optional; defaults to this
# CRON_SECRET=<random-string>                          # protects the /api/monitor 24/7 scan

